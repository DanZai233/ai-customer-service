# PostgreSQL (required; the service never falls back to in-memory data)
DATABASE_URL=postgresql://luma:luma@localhost:5432/luma_customer_service
DATABASE_POOL_SIZE=10

# Self-hosted authentication
BETTER_AUTH_SECRET=
BETTER_AUTH_SECRET_FILE=
BETTER_AUTH_URL=http://localhost:3000
AUTH_ALLOW_SIGN_UP=false
AUTH_SEED_EMAIL=admin@luma.local
AUTH_SEED_PASSWORD=
AUTH_SEED_PASSWORD_FILE=

# Root key used only to encrypt sensitive configuration stored in PostgreSQL.
# Daily AI/provider settings are managed in the Settings page without redeploying.
CONFIG_ENCRYPTION_KEY=
CONFIG_ENCRYPTION_KEY_FILE=

# AI/provider settings and future channel credentials are managed in the
# authenticated admin UI and stored encrypted in PostgreSQL.
