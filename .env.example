# PostgreSQL (omit only when intentionally using the in-memory demo repository)
DATABASE_URL=postgresql://luma:luma@localhost:5432/luma_customer_service
DATABASE_POOL_SIZE=10

# Self-hosted authentication
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
AUTH_ALLOW_SIGN_UP=false
AUTH_SEED_EMAIL=admin@luma.local
AUTH_SEED_PASSWORD=

# Volcengine Ark preset (recommended for Doubao models)
# AI_PROVIDER=volcengine
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_API_KEY=
# ARK_MODEL=

# Generic OpenAI-compatible provider (demo mode is used when omitted)
AI_PROVIDER_NAME=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# External channel integrations
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_WEBHOOK_SECRET=
